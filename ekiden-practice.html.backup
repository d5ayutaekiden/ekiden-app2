<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>女子駅伝部 練習記録</title>
  <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', Meiryo, sans-serif; }
    .tmpl-btn { font-size: 11px; padding: 2px 7px; background: #f3f4f6; border: 1px solid #d1d5db; border-radius: 4px; cursor: pointer; transition: background 0.15s; }
    .tmpl-btn:hover { background: #dbeafe; }
    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button { opacity: 1; }
    .tab-active { border-bottom: 2px solid #2563eb; color: #2563eb; background: #eff6ff; }
    .tab-inactive { border-bottom: 2px solid transparent; color: #6b7280; }
    .tab-inactive:hover { background: #f9fafb; color: #374151; }
    .modal-overlay { position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:50;display:flex;align-items:center;justify-content:center;padding:1rem; }
    .sync-toast { position:fixed;bottom:1.25rem;right:1rem;z-index:60;padding:.6rem 1rem;border-radius:.75rem;font-size:.8rem;font-weight:600;box-shadow:0 4px 12px rgba(0,0,0,.15);animation:slideUp .25s ease; }
    @keyframes slideUp { from{transform:translateY(20px);opacity:0} to{transform:translateY(0);opacity:1} }
  </style>
</head>
<body class="bg-gray-100 min-h-screen">
<div id="root"></div>

<script type="text/babel">
const { useState, useEffect, useRef, useCallback } = React;

// ======================================================
// CONSTANTS
// ======================================================
const ATHLETES_DATA = [
  { name: '瀬木彩花',   group: 'A組' },
  { name: '山田未唯',   group: 'A組' },
  { name: '村岡美玖',   group: 'A組' },
  { name: '力丸楓',     group: 'A組' },
  { name: '石黒碧海',   group: 'A組' },
  { name: '近藤希美',   group: 'B組' },
  { name: '山田桃子',   group: 'B組' },
  { name: '岡藤美音',   group: 'B組' },
  { name: '親川杏花',   group: 'B組' },
  { name: '長岡みさき', group: 'B組' },
  { name: '細川あおい', group: 'C組' },
  { name: '橋本和叶',   group: 'C組' },
  { name: '細見芽生',   group: 'C組' },
  { name: '金森詩絵菜', group: 'C組' },
  { name: '岡本彩希',   group: 'C組' },
  { name: '真柴愛里',   group: '新入生' },
  { name: '木下歩穂',   group: '新入生' },
  { name: '木村真桜',   group: '新入生' },
  { name: '大谷芽以',   group: '新入生' },
];
const ATHLETE_NAMES = ATHLETES_DATA.map(a => a.name);
const GROUPS = ['A組', 'B組', 'C組', '新入生'];
const GROUP_MAP = {};
GROUPS.forEach(g => { GROUP_MAP[g] = ATHLETES_DATA.filter(a => a.group === g).map(a => a.name); });

const DIVISIONS    = ['朝練', '午前練', '午後練', '本練'];
const STATUS_DIVS  = ['通常', '故障', '復帰', '体調不良', '特記事項', '未入力'];
const SESSION_TYPES = ['トラック', 'ロード', 'クロカン'];
const CONTENT_TAGS  = ['各自', '集団走', 'Free', '流し', 'bike', 'walk', '休み', '別メニュー'];

const TMPL_DIST      = [200, 300, 400, 600, 800, 1000, 1200, 1600, 2000, 3000];
const TMPL_REPS      = [1, 2, 3, 4, 5, 6, 8, 10, 12, 15, 20];
const TMPL_SETS      = [1, 2, 3, 4];
const TMPL_TARGET    = ['36"切', '40"', '72"', '76"', "3'10\"", "3'15\"", "3'20\"", "3'30\"", 'LT', 'Free'];
const TMPL_REST_REPS = ['R=60"', 'R=90"', "R=2'00\"", "R=3'00\"", 'R=200m jog', 'R=200m60"', 'R=400m jog'];
const TMPL_REST_SETS = ['(空欄)', "set R=3'00\"", "set R=5'00\"", 'set R=400m jog'];

const CSV_HEADERS = [
  '日付','氏名','区分','状態区分','練習タイプ','実施タイプ','場所','内容タグ',
  '距離km','時間分','ブロックNo','距離m','本数','セット数','設定',
  '本数間レスト','セット間レスト','ポイント距離km','セッション表示名','表示用メニュー','備考'
];

// ======================================================
// UTILS
// ======================================================
let _seq = 0;
function uid() { return `${Date.now()}_${++_seq}_${Math.random().toString(36).slice(2,6)}`; }
function today() { return new Date().toISOString().slice(0, 10); }

function buildJogMenu(tag, km, min) {
  const parts = [tag || ''];
  if (km !== '' && km !== undefined && km !== null && km !== 0) parts.push(`${km}km`);
  if (min !== '' && min !== undefined && min !== null && min !== 0) parts.push(`${min}分`);
  return parts.filter(Boolean).join(' ').trim();
}

function buildPointMenu(b) {
  if (!b.distanceM && !b.reps) return '(未入力)';
  let s = `${b.distanceM || '?'}m×${b.reps || '?'}本`;
  if (parseInt(b.sets) > 1) s += `×${b.sets}set`;
  if (b.target) s += ` ${b.target}`;
  if (b.restBetweenReps) s += ` ${b.restBetweenReps}`;
  if (b.restBetweenSets) s += ` ${b.restBetweenSets}`;
  return s;
}

function buildSessionMenu(blocks) {
  return blocks.filter(b => b.distanceM).map(b => {
    const reps = parseInt(b.reps) || 1;
    const sets = parseInt(b.sets) || 1;
    if (reps === 1 && sets === 1) return `${b.distanceM}m`;
    if (sets === 1) return `${b.distanceM}m×${reps}本`;
    return `(${b.distanceM}m×${reps}本)×${sets}set`;
  }).join('+');
}

function calcPointKm(distanceM, reps, sets) {
  const d = parseFloat(distanceM) || 0;
  const r = parseInt(reps) || 0;
  const s = parseInt(sets) || 1;
  return Math.round(d * r * s / 100) / 10;
}

function newBlock(n) {
  return { id: uid(), blockNo: n, distanceM: '', reps: '', sets: 1, target: '', restBetweenReps: '', restBetweenSets: '', note: '' };
}

function recordToRow(r) {
  return [
    r.date, r.name, r.division, r.statusDiv, r.practiceType, r.sessionType || '', r.location, r.contentTag || '',
    r.distanceKm ?? '', r.durationMin ?? '',
    r.blockNo ?? '', r.distanceM ?? '', r.reps ?? '', r.sets ?? '', r.target || '',
    r.restBetweenReps || '', r.restBetweenSets || '', r.pointDistanceKm ?? '',
    r.sessionMenu || '', r.displayMenu || '', r.note || ''
  ];
}

function toCSV(records) {
  const esc = v => {
    const s = String(v ?? '');
    return (s.includes(',') || s.includes('"') || s.includes('\n')) ? `"${s.replace(/"/g,'""')}"` : s;
  };
  return [CSV_HEADERS, ...records.map(recordToRow)].map(row => row.map(esc).join(',')).join('\n');
}

function downloadCSV(records, filename) {
  const bom = '﻿';
  const blob = new Blob([bom + toCSV(records)], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename; a.click();
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}

// Apps Script への送信（no-cors: レスポンスは読めないが送信は通る）
async function postToSheets(scriptUrl, records) {
  await fetch(scriptUrl, {
    method: 'POST',
    mode: 'no-cors',
    headers: { 'Content-Type': 'text/plain' },
    body: JSON.stringify(records),
  });
}

// URL形式チェックのみ（CORSの制約でブラウザからの疎通確認は不可）
async function testSheetConnection(scriptUrl) {
  const valid = /^https:\/\/script\.google\.com\/macros\/s\/.+\/exec/.test(scriptUrl);
  if (!valid) return { ok: false, reason: 'format' };
  return { ok: true };
}

// ======================================================
// HOOKS
// ======================================================
function useLS(key, init) {
  const [val, setVal] = useState(() => {
    try { const v = localStorage.getItem(key); return v ? JSON.parse(v) : init; }
    catch { return init; }
  });
  useEffect(() => { try { localStorage.setItem(key, JSON.stringify(val)); } catch {} }, [key, val]);
  return [val, setVal];
}

// ======================================================
// SHEETS COMPONENTS
// ======================================================
function SyncToast({ state }) {
  if (!state) return null;
  const cfg = {
    syncing: { bg: 'bg-blue-600 text-white',   icon: '🔄', msg: 'Sheetsに送信中...' },
    ok:      { bg: 'bg-green-600 text-white',  icon: '✅', msg: `Sheets送信完了（${state.count}件）` },
    error:   { bg: 'bg-red-500 text-white',    icon: '❌', msg: 'Sheets送信失敗 — ローカルには保存済み' },
  }[state.status] || null;
  if (!cfg) return null;
  return (
    <div className={`sync-toast ${cfg.bg}`}>
      {cfg.icon} {cfg.msg}
    </div>
  );
}

function SettingsModal({ scriptUrl, onSave, onClose }) {
  const [url, setUrl]         = useState(scriptUrl);
  const [testing, setTesting] = useState(false);
  const [testResult, setTestResult] = useState(null); // null | 'ok' | 'error'

  const handleTest = async () => {
    if (!url.trim()) return;
    setTesting(true); setTestResult(null);
    try {
      const result = await testSheetConnection(url.trim());
      setTestResult(result.ok ? 'ok' : result.reason === 'format' ? 'format' : 'error');
    } catch {
      setTestResult('error');
    } finally {
      setTesting(false);
    }
  };

  return (
    <div className="modal-overlay" onClick={e => e.target === e.currentTarget && onClose()}>
      <div className="bg-white rounded-2xl shadow-2xl w-full max-w-lg p-5">
        <div className="flex items-center justify-between mb-4">
          <h2 className="text-base font-bold text-gray-800">⚙ Google Sheets 連携設定</h2>
          <button type="button" onClick={onClose} className="text-gray-400 hover:text-gray-600 text-xl leading-none">×</button>
        </div>

        <div className="mb-4 p-3 bg-blue-50 border border-blue-200 rounded-lg text-xs text-blue-800 leading-relaxed">
          <strong>設定手順</strong><br/>
          1. Google Sheets → 拡張機能 → Apps Script にコードを貼り付けて保存<br/>
          2. 「デプロイ」→「新しいデプロイ」→ ウェブアプリ<br/>
          3. 実行ユーザー：自分　／　アクセス：全員<br/>
          4. 発行されたURLを下に貼り付け
        </div>

        <label className="block mb-3">
          <span className="block text-xs text-gray-500 mb-1 font-semibold">Apps Script URL</span>
          <input type="url" value={url} onChange={e => { setUrl(e.target.value); setTestResult(null); }}
            placeholder="https://script.google.com/macros/s/..."
            className="w-full border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-300 outline-none font-mono" />
        </label>

        <div className="flex items-center gap-2 mb-5">
          <button type="button" onClick={handleTest} disabled={!url.trim() || testing}
            className="px-4 py-1.5 text-sm border border-blue-400 text-blue-600 rounded-lg hover:bg-blue-50 disabled:opacity-40 transition-colors">
            {testing ? '確認中...' : '接続テスト'}
          </button>
          {testResult === 'ok'     && <span className="text-xs text-green-700 font-medium">✅ URLの形式OK<br/><span className="text-gray-500 font-normal">保存後、ジョグを1件入力して保存→Sheetsに行が追加されれば接続成功です</span></span>}
          {testResult === 'format' && <span className="text-xs text-red-600 font-medium">❌ URLの形式が違います<br/><span className="text-gray-500">https://script.google.com/macros/s/.../exec の形式か確認してください</span></span>}
          {testResult === 'error'  && <span className="text-xs text-red-600 font-medium">❌ 送信できませんでした<br/><span className="text-gray-500">デプロイ設定「アクセス：全員」を再確認してください</span></span>}
        </div>

        <div className="flex gap-2 justify-end">
          <button type="button" onClick={onClose}
            className="px-4 py-2 text-sm text-gray-500 hover:text-gray-700 transition-colors">キャンセル</button>
          <button type="button" onClick={() => { onSave(url.trim()); onClose(); }}
            className="px-5 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-colors shadow-sm">
            保存
          </button>
        </div>
      </div>
    </div>
  );
}

// ======================================================
// SHARED COMPONENTS
// ======================================================
function TmplButtons({ items, onSelect }) {
  return (
    <div className="flex flex-wrap gap-1 mt-1">
      {items.map(item => (
        <button key={item} type="button" className="tmpl-btn" onClick={() => onSelect(String(item))}>
          {item}
        </button>
      ))}
    </div>
  );
}

// テンプレートボタン＋カスタム値追加
function CustomTmplField({ label, required, value, onChange, placeholder, type,
                           defaultItems, customItems, onAddCustom, onRemoveCustom }) {
  const [adding, setAdding] = useState(false);
  const [newVal, setNewVal] = useState('');
  const handleAdd = () => {
    const v = newVal.trim();
    if (!v) return;
    onAddCustom(v);
    setNewVal(''); setAdding(false);
  };
  return (
    <div>
      <label className="block text-xs text-gray-500 mb-0.5">
        {label}{required && <span className="text-red-400 ml-0.5">*</span>}
      </label>
      <input type={type || 'text'} value={value} onChange={e => onChange(e.target.value)}
        className="w-full border rounded px-2 py-1.5 text-sm focus:ring-2 focus:ring-orange-200 outline-none"
        placeholder={placeholder} />
      <div className="flex flex-wrap gap-1 mt-1">
        {defaultItems.map(item => (
          <button key={item} type="button" className="tmpl-btn"
            onClick={() => onChange(String(item))}>{item}</button>
        ))}
        {(customItems || []).map((item, i) => (
          <span key={i} className="inline-flex items-center">
            <button type="button" className="tmpl-btn"
              style={{background:'#eff6ff',borderColor:'#93c5fd',color:'#1d4ed8'}}
              onClick={() => onChange(item)}>{item}</button>
            <button type="button" onClick={() => onRemoveCustom(i)}
              className="text-red-400 hover:text-red-600 text-xs ml-0.5 leading-none">×</button>
          </span>
        ))}
        {adding ? (
          <span className="inline-flex items-center gap-1">
            <input type="text" value={newVal} onChange={e => setNewVal(e.target.value)}
              onKeyDown={e => { if (e.key==='Enter') handleAdd(); if (e.key==='Escape') setAdding(false); }}
              className="border rounded px-1.5 py-0.5 text-xs w-20 focus:ring-1 focus:ring-blue-300 outline-none"
              autoFocus placeholder="値を入力" />
            <button type="button" onClick={handleAdd}
              className="text-xs text-green-600 hover:text-green-800 font-medium">追加</button>
            <button type="button" onClick={() => { setAdding(false); setNewVal(''); }}
              className="text-xs text-gray-400 hover:text-gray-600">×</button>
          </span>
        ) : (
          <button type="button" onClick={() => setAdding(true)}
            className="tmpl-btn border-dashed text-gray-400 hover:text-blue-500 hover:border-blue-400">＋</button>
        )}
      </div>
    </div>
  );
}

function Warnings({ warns, onClose }) {
  if (!warns.length) return null;
  return (
    <div className="mb-3 p-3 bg-yellow-50 border border-yellow-300 rounded-lg">
      {warns.map((w, i) => <div key={i} className="text-sm text-yellow-800">⚠ {w}</div>)}
      <button className="text-xs text-gray-500 mt-1 underline" onClick={onClose}>閉じる</button>
    </div>
  );
}

function SavedToast({ show }) {
  if (!show) return null;
  return <span className="text-green-600 text-sm font-medium ml-3">✓ 保存しました</span>;
}

function CommonSettings({ s, onChange }) {
  const [open, setOpen] = useState(true);
  return (
    <div className="bg-white border border-gray-200 rounded-lg mb-3 shadow-sm">
      <button type="button" onClick={() => setOpen(!open)}
        className="w-full flex items-center justify-between px-4 py-2.5 font-semibold text-sm text-gray-700 bg-gray-50 rounded-t-lg hover:bg-gray-100 transition-colors">
        <span>共通設定</span>
        <span className="text-gray-400 text-xs">{open ? '▲ 閉じる' : '▼ 開く'}</span>
      </button>
      {open && (
        <div className="p-3 grid grid-cols-2 gap-2 sm:grid-cols-4">
          <label className="block">
            <span className="block text-xs text-gray-500 mb-1">日付</span>
            <input type="date" value={s.date} onChange={e => onChange('date', e.target.value)}
              className="w-full border rounded px-2 py-1.5 text-sm focus:ring-2 focus:ring-blue-300 outline-none" />
          </label>
          <label className="block">
            <span className="block text-xs text-gray-500 mb-1">区分</span>
            <select value={s.division} onChange={e => onChange('division', e.target.value)}
              className="w-full border rounded px-2 py-1.5 text-sm focus:ring-2 focus:ring-blue-300 outline-none">
              {DIVISIONS.map(d => <option key={d}>{d}</option>)}
            </select>
          </label>
          <label className="block">
            <span className="block text-xs text-gray-500 mb-1">場所</span>
            <input type="text" value={s.location} onChange={e => onChange('location', e.target.value)}
              className="w-full border rounded px-2 py-1.5 text-sm focus:ring-2 focus:ring-blue-300 outline-none" />
          </label>
          <label className="block">
            <span className="block text-xs text-gray-500 mb-1">状態区分</span>
            <select value={s.statusDiv} onChange={e => onChange('statusDiv', e.target.value)}
              className="w-full border rounded px-2 py-1.5 text-sm focus:ring-2 focus:ring-blue-300 outline-none">
              {STATUS_DIVS.map(s => <option key={s}>{s}</option>)}
            </select>
          </label>
        </div>
      )}
    </div>
  );
}

function GroupButtons({ onSelect, onClear, label }) {
  return (
    <div className="flex flex-wrap gap-1.5">
      {GROUPS.map(g => (
        <button key={g} type="button" onClick={() => onSelect(g)}
          className="px-3 py-1 text-xs rounded-full border border-indigo-300 bg-indigo-50 text-indigo-700 hover:bg-indigo-100 transition-colors font-medium">
          {g}
        </button>
      ))}
      <button type="button" onClick={() => onSelect('全員')}
        className="px-3 py-1 text-xs rounded-full border border-green-300 bg-green-50 text-green-700 hover:bg-green-100 transition-colors font-medium">
        全員
      </button>
      <button type="button" onClick={onClear}
        className="px-3 py-1 text-xs rounded-full border border-gray-300 bg-white text-gray-500 hover:bg-gray-100 transition-colors">
        解除
      </button>
    </div>
  );
}

// ======================================================
// JOG VIEW
// ======================================================
function makeJogRows() {
  return ATHLETES_DATA.map(a => ({ name: a.name, group: a.group, distanceKm: '', durationMin: '', contentTag: '各自', note: '' }));
}

function JogView({ common, onSave }) {
  const [rows, setRows]           = useState(makeJogRows);
  const [groupFilter, setFilter]  = useState('全員');
  const [warns, setWarns]         = useState([]);
  const [saved, setSaved]         = useState(false);

  const displayed = groupFilter === '全員' ? rows : rows.filter(r => r.group === groupFilter);

  const update = (name, field, val) =>
    setRows(prev => prev.map(r => r.name === name ? { ...r, [field]: val } : r));

  const applyGroupFilter = g => {
    if (g === '全員') setFilter('全員');
    else setFilter(prev => prev === g ? '全員' : g);
  };

  const handleSave = () => {
    const w = [];
    const dateMs = new Date(common.s.date).getTime();
    const nowMs  = Date.now();
    if (dateMs > nowMs + 30 * 86400000)  w.push('日付が30日以上未来です。確認してください。');
    if (dateMs < nowMs - 365 * 86400000) w.push('日付が1年以上前です。確認してください。');

    const filled = rows.filter(r => r.distanceKm !== '' || r.durationMin !== '');
    filled.forEach(r => {
      if (r.distanceKm !== '' && parseFloat(r.distanceKm) > 50)
        w.push(`${r.name}: 距離が50kmを超えています。`);
    });

    const toSave = rows.filter(r => r.distanceKm !== '' || r.durationMin !== '' || r.note !== '');
    if (toSave.length === 0) {
      setWarns(['入力された行がありません（距離・時間・備考のいずれかを入力してください）。']);
      return;
    }
    setWarns(w);
    const recs = toSave.map(r => ({
      id: uid(), date: common.s.date, name: r.name, division: common.s.division,
      statusDiv: common.s.statusDiv, practiceType: 'ジョグ・各自', sessionType: '',
      location: common.s.location,
      distanceKm: r.distanceKm !== '' ? parseFloat(r.distanceKm) : '',
      durationMin: r.durationMin !== '' ? parseInt(r.durationMin) : '',
      contentTag: r.contentTag,
      displayMenu: buildJogMenu(r.contentTag, r.distanceKm, r.durationMin),
      note: r.note,
      blockNo: '', distanceM: '', reps: '', sets: '', target: '',
      restBetweenReps: '', restBetweenSets: '', pointDistanceKm: '',
    }));
    onSave(recs);
    setSaved(true);
    setRows(makeJogRows());
    setTimeout(() => setSaved(false), 3000);
  };

  return (
    <div>
      <CommonSettings s={common.s} onChange={common.onChange} />

      <div className="flex flex-wrap gap-2 mb-3 items-center">
        <span className="text-xs text-gray-500 font-medium">表示絞込:</span>
        {['全員', ...GROUPS].map(g => (
          <button key={g} type="button" onClick={() => applyGroupFilter(g)}
            className={`px-3 py-1 text-xs rounded-full border transition-colors font-medium
              ${groupFilter === g ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-600 border-gray-300 hover:bg-gray-50'}`}>
            {g}
          </button>
        ))}
      </div>

      <Warnings warns={warns} onClose={() => setWarns([])} />

      <div className="overflow-x-auto rounded-lg border border-gray-200 shadow-sm bg-white">
        <table className="w-full text-sm min-w-[520px]">
          <thead className="bg-gray-50 border-b border-gray-200">
            <tr>
              <th className="px-3 py-2.5 text-left text-xs text-gray-500 font-semibold w-28">選手名</th>
              <th className="px-2 py-2.5 text-center text-xs text-gray-500 font-semibold w-20">距離 km</th>
              <th className="px-2 py-2.5 text-center text-xs text-gray-500 font-semibold w-20">時間 分</th>
              <th className="px-2 py-2.5 text-center text-xs text-gray-500 font-semibold w-28">内容タグ</th>
              <th className="px-2 py-2.5 text-left text-xs text-gray-500 font-semibold">備考</th>
            </tr>
          </thead>
          <tbody>
            {displayed.map((row, i) => (
              <tr key={row.name} className={i % 2 === 0 ? 'bg-white' : 'bg-gray-50/60'}>
                <td className="px-3 py-1.5">
                  <span className="font-medium text-gray-800 text-xs block leading-tight">{row.name}</span>
                  <span className="text-xs text-gray-400">{row.group}</span>
                </td>
                <td className="px-2 py-1.5">
                  <input type="number" step="0.1" min="0" value={row.distanceKm}
                    onChange={e => update(row.name, 'distanceKm', e.target.value)}
                    className="w-full border rounded px-2 py-1 text-sm text-right focus:ring-2 focus:ring-blue-200 outline-none"
                    placeholder="—" />
                </td>
                <td className="px-2 py-1.5">
                  <input type="number" step="1" min="0" value={row.durationMin}
                    onChange={e => update(row.name, 'durationMin', e.target.value)}
                    className="w-full border rounded px-2 py-1 text-sm text-right focus:ring-2 focus:ring-blue-200 outline-none"
                    placeholder="—" />
                </td>
                <td className="px-2 py-1.5">
                  <select value={row.contentTag} onChange={e => update(row.name, 'contentTag', e.target.value)}
                    className="w-full border rounded px-1 py-1 text-xs focus:ring-2 focus:ring-blue-200 outline-none">
                    {CONTENT_TAGS.map(t => <option key={t}>{t}</option>)}
                  </select>
                </td>
                <td className="px-2 py-1.5">
                  <input type="text" value={row.note}
                    onChange={e => update(row.name, 'note', e.target.value)}
                    className="w-full border rounded px-2 py-1 text-sm focus:ring-2 focus:ring-blue-200 outline-none"
                    placeholder="（任意）" />
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div className="mt-4 flex items-center gap-3">
        <button type="button" onClick={handleSave}
          className="px-6 py-2.5 bg-blue-600 text-white rounded-lg font-semibold text-sm hover:bg-blue-700 active:bg-blue-800 transition-colors shadow-sm">
          保存（入力済みのみ）
        </button>
        <SavedToast show={saved} />
      </div>
    </div>
  );
}

// ======================================================
// BLOCK CARD (Point Practice)
// ======================================================
function BlockCard({ block, idx, total, onChange, onDelete, ct, onAddCt, onRemoveCt }) {
  const set = (field, val) => onChange(block.id, field, val);
  const preview = buildPointMenu(block);
  const km = calcPointKm(block.distanceM, block.reps, block.sets);

  return (
    <div className="border border-gray-200 rounded-xl p-3 bg-white shadow-sm mb-3">
      <div className="flex items-center justify-between mb-2">
        <span className="text-xs font-bold text-gray-500 uppercase tracking-wide">ブロック {idx + 1}</span>
        <div className="flex items-center gap-2">
          {km > 0 && <span className="text-xs text-blue-600 font-medium bg-blue-50 px-2 py-0.5 rounded-full">{km} km</span>}
          {total > 1 && (
            <button type="button" onClick={() => onDelete(block.id)}
              className="text-red-400 hover:text-red-600 text-base leading-none w-6 h-6 flex items-center justify-center rounded hover:bg-red-50 transition-colors">
              ×
            </button>
          )}
        </div>
      </div>

      <div className="grid grid-cols-3 gap-2 mb-2">
        <CustomTmplField label="距離 m" required type="number"
          value={block.distanceM} onChange={v => set('distanceM', v)} placeholder="1000"
          defaultItems={TMPL_DIST} customItems={ct.dist}
          onAddCustom={v => onAddCt('dist', v)} onRemoveCustom={i => onRemoveCt('dist', i)} />
        <CustomTmplField label="本数" required type="number"
          value={block.reps} onChange={v => set('reps', v)} placeholder="5"
          defaultItems={TMPL_REPS} customItems={ct.reps}
          onAddCustom={v => onAddCt('reps', v)} onRemoveCustom={i => onRemoveCt('reps', i)} />
        <CustomTmplField label="セット数" type="number"
          value={block.sets} onChange={v => set('sets', v)} placeholder="1"
          defaultItems={TMPL_SETS} customItems={ct.sets}
          onAddCustom={v => onAddCt('sets', v)} onRemoveCustom={i => onRemoveCt('sets', i)} />
      </div>

      <div className="grid grid-cols-1 gap-2 sm:grid-cols-3 mb-2">
        <CustomTmplField label="設定"
          value={block.target} onChange={v => set('target', v)} placeholder="3'10&quot;"
          defaultItems={TMPL_TARGET} customItems={ct.target}
          onAddCustom={v => onAddCt('target', v)} onRemoveCustom={i => onRemoveCt('target', i)} />
        <CustomTmplField label="本数間レスト"
          value={block.restBetweenReps} onChange={v => set('restBetweenReps', v)} placeholder="R=2'00&quot;"
          defaultItems={TMPL_REST_REPS} customItems={ct.restReps}
          onAddCustom={v => onAddCt('restReps', v)} onRemoveCustom={i => onRemoveCt('restReps', i)} />
        <CustomTmplField label="セット間レスト"
          value={block.restBetweenSets} onChange={v => set('restBetweenSets', v === '(空欄)' ? '' : v)} placeholder="（任意）"
          defaultItems={TMPL_REST_SETS} customItems={ct.restSets}
          onAddCustom={v => onAddCt('restSets', v)} onRemoveCustom={i => onRemoveCt('restSets', i)} />
      </div>

      <div>
        <label className="block text-xs text-gray-500 mb-0.5">備考</label>
        <input type="text" value={block.note} onChange={e => set('note', e.target.value)}
          className="w-full border rounded px-2 py-1.5 text-sm focus:ring-2 focus:ring-orange-200 outline-none" placeholder="（任意）" />
      </div>

      {preview !== '(未入力)' && (
        <div className="mt-2.5 px-3 py-1.5 bg-orange-50 border border-orange-200 rounded-lg text-xs text-orange-800 font-mono">
          → {preview}
        </div>
      )}
    </div>
  );
}

// ======================================================
// POINT VIEW
// ======================================================
const EMPTY_CT = { dist:[], reps:[], sets:[], target:[], restReps:[], restSets:[] };

function PointView({ common, onSave, templates, onSaveTemplate, onUpdateTemplate, onDeleteTemplate }) {
  const [sessionType, setSessionType] = useState('トラック');
  const [blocks, setBlocks]           = useState([newBlock(1)]);
  const [sessionMenu, setSessionMenu] = useState('');
  const [selected, setSelected]       = useState(new Set());
  // menus: { [name]: { sessionMenu, blocks: [...] } }
  const [menus, setMenus]             = useState({});
  const [warns, setWarns]             = useState([]);
  const [saved, setSaved]             = useState(false);
  const [tmplName, setTmplName]       = useState('');
  const [showTmpl, setShowTmpl]       = useState(false);
  const [loadedTmplIdx, setLoadedTmplIdx] = useState(null);
  const [ct, setCt]                   = useLS('ekiden_custom_tmpl', EMPTY_CT);

  const addCt    = (field, v) => setCt(p => ({ ...p, [field]: [...(p[field]||[]), v] }));
  const removeCt = (field, i) => setCt(p => ({ ...p, [field]: p[field].filter((_,j) => j!==i) }));

  const updateBlock = (id, field, val) =>
    setBlocks(bs => bs.map(b => b.id === id ? { ...b, [field]: val } : b));
  const deleteBlock = id => setBlocks(bs => bs.filter(b => b.id !== id));
  const addBlock    = () => setBlocks(bs => [...bs, newBlock(bs.length + 1)]);

  const autoGenMenu = () => setSessionMenu(buildSessionMenu(blocks));

  const toggle = name => setSelected(prev => {
    const s = new Set(prev); s.has(name) ? s.delete(name) : s.add(name); return s;
  });
  const selectGroup = g => {
    if (g === '全員') { setSelected(new Set(ATHLETE_NAMES)); return; }
    setSelected(prev => { const s = new Set(prev); GROUP_MAP[g].forEach(n => s.add(n)); return s; });
  };

  const validateBlocks = () => {
    const w = [];
    blocks.forEach((b, i) => {
      if (!b.distanceM) w.push(`ブロック${i+1}: 距離mが未入力です`);
      if (!b.reps)      w.push(`ブロック${i+1}: 本数が未入力です`);
      if (parseInt(b.sets) === 0) w.push(`ブロック${i+1}: セット数は1以上にしてください`);
    });
    return w;
  };

  const addToAthletes = () => {
    if (selected.size === 0) { setWarns(['選手を1人以上選択してください。']); return; }
    const w = validateBlocks();
    const dups = [];
    const next = { ...menus };
    selected.forEach(name => {
      const entry = next[name] ? { ...next[name], blocks: [...next[name].blocks] }
                               : { sessionMenu, blocks: [] };
      entry.sessionMenu = sessionMenu;
      blocks.forEach(b => {
        const preview = buildPointMenu(b);
        if (entry.blocks.some(x => buildPointMenu(x) === preview)) {
          dups.push(`${name}に「${preview}」が既に登録されています`);
        } else {
          entry.blocks.push({ ...b, id: uid() });
        }
      });
      next[name] = entry;
    });
    setMenus(next);
    setWarns([...w, ...dups]);
    if (w.length === 0 && dups.length === 0) setSelected(new Set());
  };

  const deleteMenuBlock = (name, id) => {
    setMenus(prev => {
      const n = { ...prev };
      n[name] = { ...n[name], blocks: n[name].blocks.filter(b => b.id !== id) };
      if (!n[name].blocks.length) delete n[name];
      return n;
    });
  };
  const clearAthleteMenu = name => setMenus(prev => { const n={...prev}; delete n[name]; return n; });

  const handleSave = () => {
    const athletes = Object.keys(menus);
    if (!athletes.length) { setWarns(['登録済みメニューがありません。']); return; }
    const w = [];
    const dateMs = new Date(common.s.date).getTime(), nowMs = Date.now();
    if (dateMs > nowMs + 30*86400000)  w.push('日付が30日以上未来です。確認してください。');
    if (dateMs < nowMs - 365*86400000) w.push('日付が1年以上前です。確認してください。');
    const recs = [];
    athletes.forEach(name => {
      const { sessionMenu: sm, blocks: bs } = menus[name];
      bs.forEach((b, i) => {
        recs.push({
          id: uid(), date: common.s.date, name, division: common.s.division,
          statusDiv: common.s.statusDiv, practiceType: 'ポイント練習', sessionType,
          location: common.s.location, blockNo: i + 1,
          distanceM: b.distanceM !== '' ? parseInt(b.distanceM) : '',
          reps:      b.reps !== '' ? parseInt(b.reps) : '',
          sets:      parseInt(b.sets) || 1,
          target: b.target, restBetweenReps: b.restBetweenReps, restBetweenSets: b.restBetweenSets,
          pointDistanceKm: calcPointKm(b.distanceM, b.reps, b.sets),
          sessionMenu: sm, displayMenu: buildPointMenu(b), note: b.note,
          contentTag: '', distanceKm: '', durationMin: '',
        });
      });
    });
    setWarns(w);
    onSave(recs);
    setSaved(true);
    setMenus({}); setBlocks([newBlock(1)]); setSessionMenu('');
    setSelected(new Set()); setLoadedTmplIdx(null);
    setTimeout(() => setSaved(false), 3000);
  };

  const handleSaveTemplate = () => {
    if (!tmplName.trim()) return;
    const tmpl = {
      name: tmplName.trim(), sessionMenu,
      blocks: blocks.map((b, i) => ({ ...b, id: uid(), blockNo: i+1 }))
    };
    const existIdx = templates.findIndex(t => t.name === tmplName.trim());
    if (existIdx >= 0) {
      onUpdateTemplate(existIdx, tmpl);
    } else {
      onSaveTemplate(tmpl);
    }
    setTmplName(''); setShowTmpl(false); setLoadedTmplIdx(null);
  };

  const loadTemplate = (t, idx) => {
    setBlocks(t.blocks.map((b, j) => ({ ...b, id: uid(), blockNo: j+1 })));
    setSessionMenu(t.sessionMenu || '');
    setTmplName(t.name);
    setLoadedTmplIdx(idx);
    setShowTmpl(false);
  };

  const registeredNames = Object.keys(menus);
  const totalKm = registeredNames.length > 0
    ? (() => {
        const allBlocks = Object.values(menus).flatMap(e => e.blocks);
        const sum = allBlocks.reduce((a, b) => a + calcPointKm(b.distanceM, b.reps, b.sets), 0);
        return Math.round(sum * 10) / 10;
      })() : 0;

  return (
    <div>
      <CommonSettings s={common.s} onChange={common.onChange} />

      {/* Session type */}
      <div className="mb-3 bg-white border border-gray-200 rounded-lg p-3">
        <label className="block text-xs text-gray-500 mb-2 font-semibold">実施タイプ</label>
        <div className="flex gap-2 flex-wrap">
          {SESSION_TYPES.map(t => (
            <button key={t} type="button" onClick={() => setSessionType(t)}
              className={`px-4 py-1.5 rounded-full text-sm border font-medium transition-colors
                ${sessionType === t ? 'bg-orange-500 text-white border-orange-500 shadow-sm' : 'bg-white text-gray-600 border-gray-300 hover:bg-orange-50'}`}>
              {t}
            </button>
          ))}
        </div>
      </div>

      <Warnings warns={warns} onClose={() => setWarns([])} />

      {/* Saved templates */}
      {templates.length > 0 && (
        <div className="mb-3 p-3 bg-purple-50 border border-purple-200 rounded-lg">
          <div className="text-xs font-bold text-purple-700 mb-2">📌 保存済みテンプレート</div>
          <div className="space-y-1">
            {templates.map((t, i) => (
              <div key={i} className="flex items-center gap-2">
                <button type="button" onClick={() => loadTemplate(t, i)}
                  className={`flex-1 text-left px-3 py-1.5 text-xs rounded-lg border font-medium transition-colors
                    ${loadedTmplIdx === i ? 'bg-purple-200 border-purple-400 text-purple-900' : 'bg-white border-purple-300 text-purple-700 hover:bg-purple-100'}`}>
                  {t.name}
                  {t.sessionMenu && <span className="ml-1.5 text-purple-400 font-normal">{t.sessionMenu}</span>}
                </button>
                <button type="button" onClick={() => onDeleteTemplate(i)}
                  className="text-xs text-red-400 hover:text-red-600 px-1.5 py-1 rounded hover:bg-red-50 transition-colors flex-shrink-0">
                  削除
                </button>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Session menu name */}
      <div className="mb-3 bg-white border border-orange-200 rounded-xl p-3">
        <div className="flex items-center justify-between mb-1.5">
          <label className="text-xs font-bold text-gray-700">セッション表示名</label>
          <button type="button" onClick={autoGenMenu}
            className="text-xs text-blue-500 hover:text-blue-700 transition-colors">
            ブロックから自動生成 ↑
          </button>
        </div>
        <input type="text" value={sessionMenu} onChange={e => setSessionMenu(e.target.value)}
          placeholder="例: 1000m×5本+200m×5本  /  3000m変化走+2000m変化走+1000m  /  (400m+800m)×3セット"
          className="w-full border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-orange-200 outline-none" />
        <p className="text-xs text-gray-400 mt-1">記録一覧・Sheetsに「セッション表示名」列として保存されます</p>
      </div>

      {/* Block builder */}
      <div className="mb-1">
        <div className="flex items-center justify-between mb-2">
          <h3 className="text-sm font-bold text-gray-700">メニューブロック</h3>
          <span className="text-xs text-gray-400">{blocks.length} ブロック</span>
        </div>
        {blocks.map((b, i) => (
          <BlockCard key={b.id} block={b} idx={i} total={blocks.length}
            onChange={updateBlock} onDelete={deleteBlock}
            ct={ct} onAddCt={addCt} onRemoveCt={removeCt} />
        ))}
        <button type="button" onClick={addBlock}
          className="w-full py-2.5 border-2 border-dashed border-gray-300 rounded-xl text-sm text-gray-500 hover:border-blue-400 hover:text-blue-600 hover:bg-blue-50/30 transition-colors">
          ＋ ブロック追加
        </button>
      </div>

      {/* Template save */}
      <div className="mt-2 mb-5">
        {!showTmpl ? (
          <div className="flex items-center gap-3">
            <button type="button" onClick={() => setShowTmpl(true)}
              className="text-xs text-purple-600 underline hover:text-purple-800 transition-colors">
              📥 テンプレ保存
            </button>
            {loadedTmplIdx !== null && (
              <button type="button" onClick={handleSaveTemplate}
                className="text-xs text-orange-600 underline hover:text-orange-800 transition-colors">
                🔄 「{tmplName}」を上書き更新
              </button>
            )}
          </div>
        ) : (
          <div className="flex gap-2 items-center mt-1">
            <input type="text" value={tmplName} onChange={e => setTmplName(e.target.value)}
              onKeyDown={e => e.key === 'Enter' && handleSaveTemplate()}
              placeholder="テンプレート名（例: 1000×5+200×5）"
              className="border rounded px-2 py-1.5 text-sm flex-1 focus:ring-2 focus:ring-purple-200 outline-none" />
            <button type="button" onClick={handleSaveTemplate}
              className="px-3 py-1.5 text-sm bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition-colors">保存</button>
            <button type="button" onClick={() => setShowTmpl(false)}
              className="px-3 py-1.5 text-sm text-gray-500 hover:text-gray-700 transition-colors">×</button>
          </div>
        )}
      </div>

      {/* Athlete selector */}
      <div className="mb-4 p-3 bg-gray-50 border border-gray-200 rounded-xl">
        <h3 className="text-sm font-bold text-gray-700 mb-2">対象選手を選択</h3>
        <GroupButtons onSelect={selectGroup} onClear={() => setSelected(new Set())} />
        <div className="mt-2.5 grid grid-cols-3 gap-1 sm:grid-cols-4 lg:grid-cols-5">
          {ATHLETES_DATA.map(a => {
            const checked = selected.has(a.name);
            return (
              <label key={a.name}
                className={`flex items-center gap-1.5 px-2 py-1.5 rounded-lg border cursor-pointer text-xs transition-colors
                  ${checked ? 'bg-blue-50 border-blue-400 text-blue-800 font-medium' : 'bg-white border-gray-200 text-gray-600 hover:bg-gray-50'}`}>
                <input type="checkbox" checked={checked} onChange={() => toggle(a.name)}
                  className="w-3 h-3 accent-blue-600 flex-shrink-0" />
                <span className="truncate">{a.name}</span>
              </label>
            );
          })}
        </div>
        <button type="button" onClick={addToAthletes} disabled={selected.size === 0}
          className="mt-3 px-5 py-2 bg-indigo-600 text-white rounded-lg text-sm font-semibold hover:bg-indigo-700 active:bg-indigo-800 disabled:opacity-40 disabled:cursor-not-allowed transition-colors shadow-sm">
          この選手に追加（{selected.size}名）
        </button>
      </div>

      {/* Registered menus */}
      {registeredNames.length > 0 && (
        <div className="mb-4 p-3 bg-green-50 border border-green-200 rounded-xl">
          <h3 className="text-sm font-bold text-green-800 mb-3">
            ✅ 登録済みメニュー（{registeredNames.length}名）
          </h3>
          <div className="space-y-2">
            {registeredNames.map(name => {
              const entry = menus[name];
              return (
                <div key={name} className="bg-white rounded-lg p-2.5 border border-green-100">
                  <div className="flex items-center justify-between mb-1">
                    <div>
                      <span className="text-xs font-bold text-gray-700">{name}</span>
                      {entry.sessionMenu && (
                        <span className="ml-2 text-xs font-medium text-orange-600 bg-orange-50 px-1.5 py-0.5 rounded">
                          {entry.sessionMenu}
                        </span>
                      )}
                    </div>
                    <button type="button" onClick={() => clearAthleteMenu(name)}
                      className="text-xs text-red-400 hover:text-red-600 transition-colors">全削除</button>
                  </div>
                  <div className="space-y-0.5 ml-1">
                    {entry.blocks.map((b, bi) => (
                      <div key={b.id} className="flex items-center gap-2">
                        <span className="text-xs text-gray-400 w-5 flex-shrink-0">#{bi+1}</span>
                        <span className="text-xs text-gray-600 font-mono flex-1">{buildPointMenu(b)}</span>
                        <span className="text-xs text-blue-400">{calcPointKm(b.distanceM, b.reps, b.sets)}km</span>
                        <button type="button" onClick={() => deleteMenuBlock(name, b.id)}
                          className="text-xs text-red-400 hover:text-red-600 transition-colors">削除</button>
                      </div>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* Save button */}
      <div className="flex items-center gap-3">
        <button type="button" onClick={handleSave} disabled={registeredNames.length === 0}
          className="px-6 py-2.5 bg-blue-600 text-white rounded-lg font-semibold text-sm hover:bg-blue-700 active:bg-blue-800 disabled:opacity-40 disabled:cursor-not-allowed transition-colors shadow-sm">
          保存（{registeredNames.length}名分）
        </button>
        <SavedToast show={saved} />
      </div>
    </div>
  );
}

// ======================================================
// RECORDS VIEW
// ======================================================
function RecordsView({ records, onDelete, onDeleteAll, onResend, scriptUrl }) {
  const [fDate, setFDate]   = useState('');
  const [fName, setFName]   = useState('');
  const [fType, setFType]   = useState('');

  const shown = records.filter(r => {
    if (fDate && r.date !== fDate) return false;
    if (fName && !r.name.includes(fName)) return false;
    if (fType && r.practiceType !== fType) return false;
    return true;
  });

  const dl = () => downloadCSV(shown, `ekiden_${new Date().toISOString().slice(0,10)}.csv`);

  const statusColor = s =>
    s === '通常' ? 'bg-green-100 text-green-700' :
    s === '故障' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700';

  const typeColor = t => t === 'ジョグ・各自' ? 'bg-blue-100 text-blue-700' : 'bg-orange-100 text-orange-700';

  return (
    <div>
      {/* Filters */}
      <div className="grid grid-cols-2 gap-2 sm:grid-cols-3 mb-4">
        <label className="block">
          <span className="block text-xs text-gray-500 mb-1">日付</span>
          <input type="date" value={fDate} onChange={e => setFDate(e.target.value)}
            className="w-full border rounded px-2 py-1.5 text-sm focus:ring-2 focus:ring-blue-200 outline-none" />
        </label>
        <label className="block">
          <span className="block text-xs text-gray-500 mb-1">選手名</span>
          <input type="text" value={fName} onChange={e => setFName(e.target.value)}
            className="w-full border rounded px-2 py-1.5 text-sm focus:ring-2 focus:ring-blue-200 outline-none" placeholder="名前で絞込" />
        </label>
        <label className="block">
          <span className="block text-xs text-gray-500 mb-1">練習タイプ</span>
          <select value={fType} onChange={e => setFType(e.target.value)}
            className="w-full border rounded px-2 py-1.5 text-sm focus:ring-2 focus:ring-blue-200 outline-none">
            <option value="">すべて</option>
            <option>ジョグ・各自</option>
            <option>ポイント練習</option>
          </select>
        </label>
      </div>

      <div className="flex justify-between items-center mb-3 flex-wrap gap-2">
        <span className="text-sm text-gray-600">
          表示 <strong>{shown.length}</strong> 件 / 全 <strong>{records.length}</strong> 件
        </span>
        <div className="flex gap-2">
          <button type="button" onClick={dl} disabled={shown.length === 0}
            className="px-4 py-1.5 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors shadow-sm">
            ⬇ CSV
          </button>
          {scriptUrl && (
            <button type="button" onClick={() => onResend(shown)} disabled={shown.length === 0}
              className="px-4 py-1.5 bg-indigo-600 text-white text-sm rounded-lg hover:bg-indigo-700 disabled:opacity-40 disabled:cursor-not-allowed transition-colors shadow-sm">
              📤 Sheetsに再送信
            </button>
          )}
          {records.length > 0 && (
            <button type="button"
              onClick={() => { if (window.confirm('全記録を削除しますか？この操作は元に戻せません。')) onDeleteAll(); }}
              className="px-4 py-1.5 bg-red-100 text-red-600 text-sm rounded-lg hover:bg-red-200 transition-colors">
              全削除
            </button>
          )}
        </div>
      </div>

      {shown.length === 0 ? (
        <div className="text-center py-16 text-gray-400">
          <div className="text-4xl mb-3">📋</div>
          <div className="text-sm">記録がありません</div>
        </div>
      ) : (
        <div className="overflow-x-auto rounded-xl border border-gray-200 shadow-sm bg-white">
          <table className="w-full text-xs min-w-[700px]">
            <thead className="bg-gray-50 border-b border-gray-200">
              <tr>
                {['日付','氏名','区分','状態','タイプ','実施','場所','メニュー表示','距離','備考',''].map(h => (
                  <th key={h} className="px-2 py-2.5 text-left text-gray-500 font-semibold whitespace-nowrap">{h}</th>
                ))}
              </tr>
            </thead>
            <tbody className="divide-y divide-gray-100">
              {shown.map(r => (
                <tr key={r.id} className="hover:bg-blue-50/40 transition-colors">
                  <td className="px-2 py-2 whitespace-nowrap font-mono">{r.date}</td>
                  <td className="px-2 py-2 whitespace-nowrap font-medium text-gray-800">{r.name}</td>
                  <td className="px-2 py-2 whitespace-nowrap text-gray-600">{r.division}</td>
                  <td className="px-2 py-2 whitespace-nowrap">
                    <span className={`px-1.5 py-0.5 rounded text-xs font-medium ${statusColor(r.statusDiv)}`}>{r.statusDiv}</span>
                  </td>
                  <td className="px-2 py-2 whitespace-nowrap">
                    <span className={`px-1.5 py-0.5 rounded text-xs font-medium ${typeColor(r.practiceType)}`}>
                      {r.practiceType === 'ジョグ・各自' ? 'ジョグ' : 'ポイント'}
                    </span>
                  </td>
                  <td className="px-2 py-2 whitespace-nowrap text-gray-600">{r.sessionType || '—'}</td>
                  <td className="px-2 py-2 whitespace-nowrap text-gray-600">{r.location}</td>
                  <td className="px-2 py-2 font-mono text-gray-800 max-w-xs truncate" title={r.displayMenu}>{r.displayMenu}</td>
                  <td className="px-2 py-2 whitespace-nowrap text-gray-600 text-right">
                    {r.practiceType === 'ジョグ・各自'
                      ? (r.distanceKm !== '' ? `${r.distanceKm}km` : '')
                      : (r.pointDistanceKm ? `${r.pointDistanceKm}km` : '')}
                  </td>
                  <td className="px-2 py-2 text-gray-500 max-w-[100px] truncate" title={r.note}>{r.note}</td>
                  <td className="px-2 py-2">
                    <button type="button" onClick={() => onDelete(r.id)}
                      className="text-red-400 hover:text-red-600 transition-colors w-5 h-5 flex items-center justify-center rounded hover:bg-red-50">
                      ×
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  );
}

// ======================================================
// APP
// ======================================================
function App() {
  const [records, setRecords]     = useLS('ekiden_records', []);
  const [templates, setTemplates] = useLS('ekiden_templates', []);
  const [scriptUrl, setScriptUrl] = useLS('ekiden_script_url', '');
  const [tab, setTab]             = useState('jog');
  const [s, setS]                 = useState({
    date: today(), division: '本練', location: '名城G', statusDiv: '通常',
  });
  const [showSettings, setShowSettings] = useState(false);
  const [syncState, setSyncState]       = useState(null);
  const syncTimer = useRef(null);

  const onChange = (field, val) => setS(p => ({ ...p, [field]: val }));
  const common   = { s, onChange };

  const showSync = (state) => {
    setSyncState(state);
    clearTimeout(syncTimer.current);
    if (state.status !== 'syncing') {
      syncTimer.current = setTimeout(() => setSyncState(null), 4000);
    }
  };

  const sendToSheets = useCallback(async (recs) => {
    if (!scriptUrl) return;
    showSync({ status: 'syncing' });
    try {
      await postToSheets(scriptUrl, recs);
      showSync({ status: 'ok', count: recs.length });
    } catch {
      showSync({ status: 'error' });
    }
  }, [scriptUrl]);

  const addRecords = (recs) => {
    setRecords(prev => [...prev, ...recs]);
    sendToSheets(recs);
  };
  const deleteRecord  = id   => setRecords(prev => prev.filter(r => r.id !== id));
  const deleteAll     = ()   => setRecords([]);
  const addTemplate    = tmpl        => setTemplates(prev => [...prev, tmpl]);
  const updateTemplate = (idx, tmpl) => setTemplates(prev => prev.map((t,i) => i===idx ? tmpl : t));
  const deleteTemplate = idx         => setTemplates(prev => prev.filter((_,i) => i!==idx));

  const TABS = [
    { id: 'jog',     icon: '🏃', label: 'ジョグ入力' },
    { id: 'point',   icon: '⚡', label: 'ポイント練習' },
    { id: 'records', icon: '📋', label: `記録一覧 (${records.length})` },
  ];

  return (
    <div className="min-h-screen bg-gray-100">
      {/* Header */}
      <header className="bg-gradient-to-r from-blue-700 to-blue-600 text-white px-4 py-3 shadow-lg">
        <div className="flex items-center justify-between max-w-4xl mx-auto">
          <div>
            <h1 className="text-lg font-bold tracking-wide">女子駅伝部 練習記録</h1>
            <p className="text-blue-200 text-xs mt-0.5 flex items-center gap-1.5">
              Practice Record Manager
              {scriptUrl
                ? <span className="bg-green-500 text-white text-xs px-1.5 py-0.5 rounded-full">Sheets連携中</span>
                : <span className="bg-blue-500/60 text-blue-100 text-xs px-1.5 py-0.5 rounded-full">ローカル保存</span>}
            </p>
          </div>
          <button type="button" onClick={() => setShowSettings(true)}
            className="w-9 h-9 flex items-center justify-center rounded-full bg-blue-500/40 hover:bg-blue-500/70 transition-colors text-lg"
            title="設定">⚙</button>
        </div>
      </header>

      {/* Tab nav */}
      <nav className="bg-white border-b border-gray-200 shadow-sm sticky top-0 z-20">
        <div className="flex max-w-4xl mx-auto">
          {TABS.map(t => (
            <button key={t.id} type="button" onClick={() => setTab(t.id)}
              className={`flex-1 py-3 px-2 text-xs sm:text-sm font-medium transition-colors
                ${tab === t.id ? 'tab-active' : 'tab-inactive'}`}>
              <span className="mr-1">{t.icon}</span>
              <span className="hidden xs:inline sm:inline">{t.label}</span>
              <span className="inline sm:hidden">
                {t.id === 'jog' ? 'ジョグ' : t.id === 'point' ? 'ポイント' : `記録(${records.length})`}
              </span>
            </button>
          ))}
        </div>
      </nav>

      {/* Main */}
      <main className="max-w-4xl mx-auto p-3 sm:p-4 pb-12">
        {tab === 'jog'     && <JogView     common={common} onSave={addRecords} />}
        {tab === 'point'   && <PointView   common={common} onSave={addRecords}
                                templates={templates} onSaveTemplate={addTemplate}
                                onUpdateTemplate={updateTemplate} onDeleteTemplate={deleteTemplate} />}
        {tab === 'records' && <RecordsView records={records} onDelete={deleteRecord}
                                onDeleteAll={deleteAll} scriptUrl={scriptUrl}
                                onResend={recs => sendToSheets(recs)} />}
      </main>

      {/* Settings modal */}
      {showSettings && (
        <SettingsModal scriptUrl={scriptUrl}
          onSave={url => setScriptUrl(url)}
          onClose={() => setShowSettings(false)} />
      )}

      {/* Sync toast */}
      <SyncToast state={syncState} />
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>
</body>
</html>
